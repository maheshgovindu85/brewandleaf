# Backend .env (./backend/.env)

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=pmechtech0031
DB_NAME=brew_and_leaf_db

# JWT Configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# Optional: Logging Configuration
LOG_LEVEL=debug

# Optional: Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Optional: API Keys for Location Services
GEOLOCATION_API_KEY=your_geolocation_api_key

# Frontend .env (./frontend/.env)

# API Configuration
API_URL=http://localhost:5000/api

# Authentication
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_EXPIRE_DAYS=7

# Feature Flags
ENABLE_GEOLOCATION=true
ENABLE_NOTIFICATIONS=true

# Optional: Analytics
ANALYTICS_TRACKING_ID=your_analytics_id

# Frontend .env.production (./frontend/.env.production)

# API Configuration
API_URL=https://your-production-api.com/api

# Authentication
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_EXPIRE_DAYS=7

# Feature Flags
ENABLE_GEOLOCATION=true
ENABLE_NOTIFICATIONS=true

# Analytics
ANALYTICS_TRACKING_ID=your_production_analytics_id

